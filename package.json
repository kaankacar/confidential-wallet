{
  "name": "confidential-wallet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone confidential-token wallet on Stellar testnet with in-browser multi-account switching. No auditor UI — send/receive with hidden amounts.",
  "scripts": {
    "vendor:bb": "node scripts/vendor-bb.mjs",
    "predev": "pnpm vendor:bb",
    "dev": "vite",
    "prebuild": "pnpm vendor:bb",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ctd/sdk": "link:../confidential/oz-demo/packages/sdk",
    "@noble/curves": "^1.9.4",
    "@noble/hashes": "^1.8.0",
    "@noir-lang/noir_js": "1.0.0-beta.9",
    "@stellar/stellar-sdk": "^14.2.0",
    "@zkpassport/poseidon2": "^0.6.0",
    "buffer": "^6.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@aztec/bb.js": "0.87.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "puppeteer-core": "^25.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
